local __loops = {}
local __loop_id = 0

function __loops.create(f, interval, jitter)
    __loop_id = __loop_id + 1
    local id = __loop_id
    local active = true
    local last_run = 0

    local conn = __rns.RenderStepped:Connect(function()
        if not active then
            if conn then conn:Disconnect() end
            return
        end

        local now = __o.tick()
        local actual_interval = interval
        if jitter then
            actual_interval = interval + (__rand() * jitter - jitter / 2)
        end

        if now - last_run < actual_interval then
            return
        end
        last_run = now

        local s = __o.pcall(f)
        if not s then
            active = false
            if conn then conn:Disconnect() end
            __loops[id] = nil
        end
    end)

    __loops[id] = {
        stop = function()
            active = false
            if conn then conn:Disconnect() end
            __loops[id] = nil
        end,
        id = id
    }

    return __loops[id]
end

