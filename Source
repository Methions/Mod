local __mod_count = 0
local __last_mod_time = 0

local function __apply_mods()
    if not __cfg.e then return 0 end

    local il = __get_il()
    if not il or not il.Items then
        return 0
    end

    local shuffled = {}
    for i, p in __o.ipairs(__props) do
        shuffled[i] = p
    end
    for i = #shuffled, 2, -1 do
        local j = __rand_int(1, i)
        shuffled[i], shuffled[j] = shuffled[j], shuffled[i]
    end

    local count = 0

    for _, item in __o.pairs(il.Items) do
        if __o.type(item) == "table" then
            local modified = false

            for _, prop in __o.ipairs(shuffled) do
                if __cfg[prop.cfg] then
                    local s = __o.pcall(function()
                        if item[prop.key] ~= nil then
                            if __o.rawset then
                                __o.rawset(item, prop.key, prop.value)
                            else
                                item[prop.key] = prop.value
                            end
                            modified = true
                        end
                    end)
                end
            end

            if modified then
                count = count + 1
            end
        end
    end

    __mod_count = count
    __last_mod_time = __o.tick()
    return count
end

